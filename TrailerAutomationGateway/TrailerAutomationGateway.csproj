<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<!-- Makaretu.Dns provides mDNS service registration -->
		<PackageReference Include="Makaretu.Dns.Multicast" Version="0.27.0" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="9.0.6" />
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.0" />
		<PackageReference Include="System.Net.Http" Version="4.3.4" />
		<PackageReference Include="System.Text.RegularExpressions" Version="4.3.1" />
		<!-- LiteDB for sensor reading persistence -->
		<PackageReference Include="LiteDB" Version="5.0.21" />
	</ItemGroup>

	<ItemGroup>
	  <None Update="deploy-gateway.sh">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

	<!-- Generate build version before compilation -->
	<!-- Only generate if BuildVersion.cs doesn't exist or is older than 1 minute -->
	<Target Name="GenerateBuildVersion" BeforeTargets="BeforeBuild">
		<Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(ProjectDir)generate_version.ps1&quot;" Condition="!Exists('$(ProjectDir)BuildVersion.cs') Or $([System.DateTime]::Now.Subtract($([System.IO.File]::GetLastWriteTime('$(ProjectDir)BuildVersion.cs'))).TotalMinutes) &gt; 1" />
	</Target>

</Project>
