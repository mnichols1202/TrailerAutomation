@page "/devices"
@rendermode InteractiveServer
@inject ClientRegistry ClientRegistry
@inject DeviceCommandService CommandService
@inject SensorReadingRegistry SensorRegistry
@inject HttpClient Http
@implements IDisposable

<PageTitle>Devices</PageTitle>

<div class="page-header">
    <h2 style="margin: 0; padding: 0;">Devices</h2>
    <div class="page-header-actions">
        <span class="toolbar-meta">Updated <strong>@DateTime.Now.ToString("HH:mm:ss")</strong></span>
        <button class="btn btn-secondary" @onclick="LoadDevices">↺ Refresh</button>
        <button class="btn btn-danger" @onclick="ReInitDevices" disabled="@_isReInitializing">
            @if (_isReInitializing)
            {
                <span>Re-Initializing…</span>
            }
            else
            {
                <span>Re-Init All</span>
            }
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_reInitMessage))
{
    <div class="alert @(_reInitSuccess ? "alert-success" : "alert-danger")">
        @_reInitMessage
    </div>
}

@if (!_devices.Any())
{
    <div class="empty-state">
        <span class="empty-state-icon" style="font-size:48px; opacity:0.3;">[ ]</span>
        <p>No devices registered yet. Waiting for devices to connect…</p>
    </div>
}
else
{
    <div class="device-grid">
        @foreach (var device in _devices.OrderBy(d => d.DeviceId))
        {
            var minutesAgo = (DateTime.UtcNow - device.LastSeen).TotalMinutes;
            var isOnline = minutesAgo < 5;
            var hasSensor = _sensorReadings.TryGetValue(device.DeviceId, out var sensorReading);
            var sensorAgeMin = hasSensor ? (DateTime.UtcNow - sensorReading!.TimestampUtc).TotalMinutes : 0;

            <div class="device-card @(isOnline ? "online" : "offline")">

                <div class="dc-header">
                    <div class="dc-title">
                        <span class="dc-name">@device.DeviceId</span>
                        @if (!string.IsNullOrEmpty(device.FriendlyName))
                        {
                            <span class="dc-friendly">@device.FriendlyName</span>
                        }
                    </div>
                    <div class="dc-badges">
                        @if (!string.IsNullOrEmpty(device.DeviceType) && device.DeviceType != "Unknown")
                        {
                            <span class="device-type-badge">@device.DeviceType</span>
                        }
                        <span class="status-dot @(isOnline ? "online" : "offline")">
                            @(isOnline ? "Online" : "Offline")
                        </span>
                    </div>
                </div>

                <div class="dc-meta">
                    <span class="dc-meta-item">
                        <span class="dc-meta-label">IP</span>@device.IpAddress
                    </span>
                    <span class="dc-meta-item">
                        <span class="dc-meta-label">Port</span>@device.CommandPort
                    </span>
                    <span class="dc-meta-spacer"></span>
                    <span class="dc-last-seen">@minutesAgo.ToString("F0")m ago</span>
                </div>

                @if (device.Capabilities.Length > 0)
                {
                    <div class="capability-tags">
                        @foreach (var cap in device.Capabilities)
                        {
                            <span class="capability-tag">@cap</span>
                        }
                    </div>
                }

                @if (device.Capabilities.Contains("relay") && device.Relays != null && device.Relays.Length > 0)
                {
                    <div class="dc-relays">
                        <div class="dc-section-label">GPIO / Relays</div>
                        @foreach (var relay in device.Relays)
                        {
                            var relayIdCopy    = relay.Id;
                            var relayNameCopy  = relay.Name;
                            var deviceIdCopy   = device.DeviceId;
                            var stateStr       = device.RelayStates.GetValueOrDefault(relayIdCopy, "off");
                            var isOn           = stateStr == "on";

                            <div class="relay-row">
                                <div class="relay-info">
                                    <span class="relay-led @(isOn ? "on" : "off")"></span>
                                    <span class="relay-name">@relayNameCopy</span>
                                    <span class="relay-state-label @(isOn ? "on" : "off")">@(isOn ? "ON" : "OFF")</span>
                                </div>
                                <button class="relay-toggle-btn @(isOn ? "on" : "off")"
                                        @onclick="@(async () => await ToggleRelay(deviceIdCopy, relayIdCopy, relayNameCopy))"
                                        disabled="@(!isOnline)"
                                        title="Toggle @relayNameCopy">
                                </button>
                            </div>
                        }
                    </div>
                }
                else if (device.Capabilities.Contains("relay"))
                {
                    <div class="dc-relays">
                        <div class="dc-section-label">GPIO / Relays</div>
                        <span style="font-size: 12px; color: var(--text-tertiary);">No relay info received yet</span>
                    </div>
                }

                @if (hasSensor)
                {
                    <div class="dc-sensor">
                        <div class="dc-sensor-reading">
                            <span class="dc-sensor-value temp">@sensorReading!.TemperatureC.ToString("F1")</span>
                            <span class="dc-sensor-unit">°C</span>
                        </div>
                        <span class="dc-sensor-sub">/ @((sensorReading.TemperatureC * 9.0 / 5.0 + 32).ToString("F1"))°F</span>
                        <div class="dc-sensor-reading" style="margin-left: 8px;">
                            <span class="dc-sensor-value humidity">@sensorReading.HumidityPercent.ToString("F1")</span>
                            <span class="dc-sensor-unit">%</span>
                        </div>
                        <span class="dc-sensor-age">@sensorAgeMin.ToString("F0")m ago</span>
                    </div>
                }

                @if (_commandResults.TryGetValue(device.DeviceId, out var result))
                {
                    <div class="cmd-result @(result.Success ? "success" : "error")">
                        <span class="cmd-result-msg">
                            @(result.Success ? "✓" : "✗") @result.Message
                            @if (!string.IsNullOrEmpty(result.ErrorCode))
                            {
                                <span style="opacity: 0.65; font-size: 11px;"> (@result.ErrorCode)</span>
                            }
                        </span>
                        <button class="btn btn-secondary" style="padding: 3px 8px; font-size: 11px;"
                                @onclick="() => ClearResult(device.DeviceId)">✕</button>
                    </div>
                }

                <div class="dc-actions">
                    <button class="btn btn-warning"
                            @onclick="() => RebootDevice(device.DeviceId)"
                            disabled="@(!isOnline)"
                            title="Reboot device">
                        ↺ Reboot
                    </button>
                    <button class="btn btn-danger"
                            @onclick="() => EnterBootselMode(device.DeviceId)"
                            disabled="@(!isOnline)"
                            title="Enter BOOTSEL / download mode for firmware upload">
                        BOOTSEL
                    </button>
                    <button class="btn btn-info"
                            @onclick="() => ShowDeviceConfig(device.DeviceId)"
                            disabled="@(!isOnline)"
                            title="View device configuration">
                        ℹ Info
                    </button>
                    <button class="btn btn-purple"
                            @onclick="() => EditDeviceConfig(device.DeviceId)"
                            disabled="@(!isOnline)"
                            title="Edit device configuration">
                        ✎ Config
                    </button>
                    <button class="btn btn-ota"
                            @onclick="() => OpenOtaModal(device.DeviceId)"
                            disabled="@(!isOnline)"
                            title="Flash firmware over-the-air">
                        ⬆ Flash
                    </button>
                </div>

            </div>
        }
    </div>
}

@if (_showConfigModal)
{
    <div class="modal-overlay" @onclick="CloseConfigModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Device Configuration</h3>
                <button class="modal-close" @onclick="CloseConfigModal">✕</button>
            </div>
            <div class="modal-body">
                @if (_configLoading)
                {
                    <p style="text-align:center; padding:30px; color:var(--text-secondary);">Loading…</p>
                }
                else if (!string.IsNullOrEmpty(_configError))
                {
                    <div class="alert alert-danger">✗ @_configError</div>
                }
                else if (!string.IsNullOrEmpty(_deviceConfig))
                {
                    <pre>@_deviceConfig</pre>
                }
            </div>
        </div>
    </div>
}

@if (_showOtaModal)
{
    <div class="modal-overlay" @onclick="CloseOtaModal">
        <div class="modal-content" style="max-width:480px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>⬆ Flash Firmware — @_otaDeviceId</h3>
                <button class="modal-close" @onclick="CloseOtaModal">✕</button>
            </div>
            <div class="modal-body">
                @if (_otaUploading)
                {
                    <p style="text-align:center; padding:30px; color:var(--text-secondary);">Uploading and flashing…</p>
                }
                else
                {
                    <p style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;">
                        Select a <strong>.bin</strong> firmware file built by PlatformIO.
                        The device will download and apply it, then reboot automatically.
                    </p>

                    <InputFile OnChange="OtaFileSelected" accept=".bin" style="width:100%; margin-bottom:12px;" />

                    @if (!string.IsNullOrEmpty(_otaFilename))
                    {
                        <p style="font-size:12px; color:var(--text-secondary);">Selected: @_otaFilename (@(_otaFileSize / 1024) KB)</p>
                    }

                    @if (!string.IsNullOrEmpty(_otaError))
                    {
                        <div class="alert alert-danger">✗ @_otaError</div>
                    }
                    @if (!string.IsNullOrEmpty(_otaSuccess))
                    {
                        <div class="alert alert-success">✓ @_otaSuccess</div>
                    }

                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseOtaModal">Cancel</button>
                        <button class="btn btn-ota" @onclick="StartOtaFlash"
                                disabled="@(_otaFileData == null || _otaUploading)">
                            ⬆ Flash Now
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (_showConfigEditor)
{
    <div class="modal-overlay" @onclick="CloseConfigEditor">
        <div class="modal-content" style="max-width:860px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>✎ Edit Config — @_editingDeviceId</h3>
                <button class="modal-close" @onclick="CloseConfigEditor">✕</button>
            </div>
            <div class="modal-body">
                @if (_configLoading)
                {
                    <p style="text-align:center; padding:30px; color:var(--text-secondary);">Loading…</p>
                }
                else if (!string.IsNullOrEmpty(_configError))
                {
                    <div class="alert alert-danger">✗ @_configError</div>
                    <button class="btn btn-secondary" @onclick="() => EditDeviceConfig(_editingDeviceId!)">↺ Retry</button>
                }
                else
                {
                    <textarea @bind="_editedConfig" spellcheck="false"></textarea>

                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div class="alert alert-danger" style="margin-top:10px;">✗ @_saveError</div>
                    }
                    @if (!string.IsNullOrEmpty(_saveSuccess))
                    {
                        <div class="alert alert-success" style="margin-top:10px;">✓ @_saveSuccess</div>
                    }

                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseConfigEditor">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveConfig" disabled="@_saving">
                            @(_saving ? "Saving…" : "Save")
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<DeviceInfo> _devices = new();
    private Dictionary<string, CommandResult> _commandResults = new();
    private Dictionary<string, SensorReading> _sensorReadings = new();
    private System.Threading.Timer? _timer;
    private bool _isReInitializing = false;
    private string _reInitMessage = string.Empty;
    private bool _reInitSuccess = false;
    private bool _showConfigModal = false;
    private bool _showConfigEditor = false;
    private bool _configLoading = false;
    private bool _saving = false;
    private string _deviceConfig = string.Empty;
    private string _editedConfig = string.Empty;
    private string _configError = string.Empty;
    private string _saveError = string.Empty;
    private string _saveSuccess = string.Empty;
    private string? _editingDeviceId = null;

    // OTA state
    private bool _showOtaModal = false;
    private bool _otaUploading = false;
    private string? _otaDeviceId = null;
    private byte[]? _otaFileData = null;
    private string _otaFilename = string.Empty;
    private long _otaFileSize = 0;
    private string _otaError = string.Empty;
    private string _otaSuccess = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevices();

        ClientRegistry.OnRelayStateChanged += HandleRelayStateChanged;

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadDevices();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async void HandleRelayStateChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadDevices();
            StateHasChanged();
        });
    }

    private Task LoadDevices()
    {
        try
        {
            var clients = ClientRegistry.GetAllClients();
            _devices = clients.Select(c => new DeviceInfo
            {
                ClientId = c.ClientId,
                DeviceType = c.DeviceType ?? "Unknown",
                FriendlyName = c.FriendlyName,
                RemoteIp = c.RemoteIp,
                FirstSeenUtc = c.FirstSeenUtc,
                LastHeartbeatUtc = c.LastHeartbeatUtc,
                CommandPort = c.CommandPort,
                Capabilities = c.Capabilities?.ToArray() ?? Array.Empty<string>(),
                Relays = c.Relays?.Select(r => new RelayInfo { Id = r.Id, Name = r.Name }).ToArray(),
                RelayStates = new Dictionary<string, string>(c.RelayStates)
            }).ToList();

            _sensorReadings = SensorRegistry.GetAllReadings()
                .ToDictionary(r => r.ClientId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading devices: {ex.Message}");
        }

        return Task.CompletedTask;
    }

    private async Task ToggleRelay(string deviceId, string relayId, string relayName)
    {
        try
        {
            var device = ClientRegistry.GetClient(deviceId);
            var currentState = device?.RelayStates.GetValueOrDefault(relayId, "off") ?? "off";
            var newState = currentState == "on" ? "off" : "on";

            _commandResults.Remove(deviceId);

            var result = await CommandService.SendSetRelayCommandAsync(deviceId, relayId, newState);

            if (result != null)
            {
                _commandResults[deviceId] = result;

                if (result.Success)
                {
                    ClientRegistry.UpdateRelayState(deviceId, relayId, newState);
                    await LoadDevices();
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _commandResults[deviceId] = new CommandResult
            {
                Success = false,
                Message = $"Error: {ex.Message}",
                ErrorCode = "CLIENT_ERROR"
            };
            StateHasChanged();
        }
    }

    private void ClearResult(string deviceId)
    {
        _commandResults.Remove(deviceId);
        StateHasChanged();
    }

    private async Task ReInitDevices()
    {
        _isReInitializing = true;
        _reInitMessage = string.Empty;
        StateHasChanged();

        try
        {
            var devices = ClientRegistry.GetAllClients().ToList();
            if (!devices.Any())
            {
                _reInitMessage = "No devices to re-initialize";
                _reInitSuccess = false;
                return;
            }

            var successCount = 0;
            var failedDevices = new List<string>();

            foreach (var device in devices)
            {
                try
                {
                    var initCommand = new DeviceCommand
                    {
                        CommandId = Guid.NewGuid().ToString(),
                        Type = "init",
                        Payload = System.Text.Json.JsonSerializer.SerializeToElement(new { })
                    };

                    var result = await CommandService.SendCommandAsync(device.ClientId, initCommand);

                    if (result != null && result.Success)
                        successCount++;
                    else
                        failedDevices.Add(device.ClientId);
                }
                catch
                {
                    failedDevices.Add(device.ClientId);
                }

                StateHasChanged();
            }

            foreach (var clientId in failedDevices)
                ClientRegistry.RemoveClient(clientId);

            _reInitMessage = $"Re-init complete: {successCount} devices will re-register, {failedDevices.Count} removed";
            _reInitSuccess = successCount > 0;

            await Task.Delay(2000);
            await LoadDevices();
        }
        catch (Exception ex)
        {
            _reInitMessage = $"Re-initialization failed: {ex.Message}";
            _reInitSuccess = false;
        }
        finally
        {
            _isReInitializing = false;
            StateHasChanged();
        }
    }

    private async Task RebootDevice(string deviceId)
    {
        try
        {
            var result = await CommandService.SendCommandAsync(deviceId, new DeviceCommand
            {
                CommandId = Guid.NewGuid().ToString(),
                Type = "reboot",
                Payload = System.Text.Json.JsonSerializer.SerializeToElement(new { })
            });

            _commandResults[deviceId] = result != null && result.Success
                ? new CommandResult { Success = true, Message = "Device is rebooting…" }
                : new CommandResult { Success = false, Message = result?.Message ?? "Reboot failed", ErrorCode = "REBOOT_ERROR" };
        }
        catch (Exception ex)
        {
            _commandResults[deviceId] = new CommandResult { Success = false, Message = ex.Message, ErrorCode = "REBOOT_ERROR" };
        }

        StateHasChanged();
    }

    private async Task EnterBootselMode(string deviceId)
    {
        try
        {
            var result = await CommandService.SendCommandAsync(deviceId, new DeviceCommand
            {
                CommandId = Guid.NewGuid().ToString(),
                Type = "bootsel",
                Payload = System.Text.Json.JsonSerializer.SerializeToElement(new { })
            });

            _commandResults[deviceId] = result != null && result.Success
                ? new CommandResult { Success = true, Message = "Entering BOOTSEL mode. Upload firmware via PlatformIO." }
                : new CommandResult { Success = false, Message = result?.Message ?? "BOOTSEL failed", ErrorCode = "BOOTSEL_ERROR" };
        }
        catch (Exception ex)
        {
            _commandResults[deviceId] = new CommandResult { Success = false, Message = ex.Message, ErrorCode = "BOOTSEL_ERROR" };
        }

        StateHasChanged();
    }

    private async Task ShowDeviceConfig(string deviceId)
    {
        _showConfigModal = true;
        _configLoading = true;
        _deviceConfig = string.Empty;
        _configError = string.Empty;
        StateHasChanged();

        try
        {
            var result = await CommandService.SendCommandAsync(deviceId, new DeviceCommand
            {
                CommandId = Guid.NewGuid().ToString(),
                Type = "getConfig",
                Payload = System.Text.Json.JsonSerializer.SerializeToElement(new { })
            });

            if (result != null && result.Success && result.Data != null)
                _deviceConfig = FormatConfiguration(deviceId, result.Data);
            else
                _configError = result?.Message ?? "Failed to retrieve configuration";
        }
        catch (Exception ex)
        {
            _configError = $"Error: {ex.Message}";
        }
        finally
        {
            _configLoading = false;
            StateHasChanged();
        }
    }

    private string FormatConfiguration(string deviceId, object configData)
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(configData);
            var config = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(json);

            var sb = new System.Text.StringBuilder();
            sb.AppendLine("=== Configuration ===");
            sb.AppendLine();

            if (config.TryGetProperty("buildVersion", out var buildVersion))
            {
                sb.AppendLine($"Build Version: {buildVersion.GetString()}");
                sb.AppendLine();
            }

            if (config.TryGetProperty("device", out var device))
            {
                sb.AppendLine("Device:");
                sb.AppendLine($"  ClientId: {device.GetProperty("clientId").GetString()}");
                sb.AppendLine($"  DeviceType: {device.GetProperty("deviceType").GetString()}");
                sb.AppendLine($"  FriendlyName: {device.GetProperty("friendlyName").GetString()}");
                sb.AppendLine($"  Command Listener Port: {device.GetProperty("commandListenerPort").GetInt32()}");
                sb.AppendLine();
            }

            if (config.TryGetProperty("intervals", out var intervals))
            {
                sb.AppendLine("Intervals:");
                sb.AppendLine($"  Heartbeat: {intervals.GetProperty("heartbeatSeconds").GetInt32()}s");
                if (intervals.TryGetProperty("commandPollingSeconds", out var polling))
                    sb.AppendLine($"  Command Polling: {polling.GetInt32()}s");
                sb.AppendLine("  (Sensor intervals configured per-sensor below)");
                sb.AppendLine();
            }

            if (config.TryGetProperty("gateway", out var gateway))
            {
                sb.AppendLine("Gateway:");
                if (gateway.TryGetProperty("discoveryTimeoutSeconds", out var timeout))
                    sb.AppendLine($"  Discovery Timeout: {timeout.GetInt32()}s");
                sb.AppendLine();
            }

            if (config.TryGetProperty("relays", out var relays) && relays.GetArrayLength() > 0)
            {
                sb.AppendLine($"Relays ({relays.GetArrayLength()}):");
                foreach (var relay in relays.EnumerateArray())
                {
                    var id = relay.GetProperty("id").GetString();
                    var name = relay.GetProperty("name").GetString();
                    var pin = relay.GetProperty("pin").GetInt32();
                    var initialState = relay.GetProperty("initialState").GetBoolean();
                    sb.AppendLine($"  [{id}] {name} — Pin: {pin}, Initial: {(initialState ? "ON" : "OFF")}");
                }
                sb.AppendLine();
            }

            if (config.TryGetProperty("sensors", out var sensors) && sensors.GetArrayLength() > 0)
            {
                sb.AppendLine($"Sensors ({sensors.GetArrayLength()}):");
                foreach (var sensor in sensors.EnumerateArray())
                {
                    var id       = sensor.GetProperty("id").GetString();
                    var type     = sensor.GetProperty("type").GetString();
                    var name     = sensor.GetProperty("name").GetString();
                    var i2c      = sensor.GetProperty("i2cAddress").GetString();
                    var enabled  = sensor.GetProperty("enabled").GetBoolean();
                    var interval = sensor.GetProperty("readingIntervalSeconds").GetInt32();
                    sb.AppendLine($"  [{id}] {name} — Type: {type}, I2C: {i2c}, Enabled: {enabled}, Interval: {interval}s");
                }
                sb.AppendLine();
            }

            if (config.TryGetProperty("buttons", out var buttons) && buttons.GetArrayLength() > 0)
            {
                sb.AppendLine($"Buttons ({buttons.GetArrayLength()}):");
                foreach (var button in buttons.EnumerateArray())
                {
                    var id           = button.GetProperty("id").GetString();
                    var name         = button.GetProperty("name").GetString();
                    var pin          = button.GetProperty("pin").GetInt32();
                    var targetDevice = button.GetProperty("targetDevice").GetString();
                    var targetRelay  = button.GetProperty("targetRelay").GetString();
                    var enabled      = button.GetProperty("enabled").GetBoolean();
                    sb.AppendLine($"  [{id}] {name} — Pin: {pin}, Target: {targetDevice}/{targetRelay}, Enabled: {enabled}");
                }
                sb.AppendLine();
            }

            sb.AppendLine("=====================");
            return sb.ToString();
        }
        catch (Exception ex)
        {
            return $"Error formatting configuration: {ex.Message}";
        }
    }

    private void CloseConfigModal()
    {
        _showConfigModal = false;
        StateHasChanged();
    }

    private async Task EditDeviceConfig(string deviceId)
    {
        _editingDeviceId = deviceId;
        _showConfigEditor = true;
        _configLoading = true;
        _editedConfig = string.Empty;
        _configError = string.Empty;
        _saveError = string.Empty;
        _saveSuccess = string.Empty;
        StateHasChanged();

        try
        {
            var httpClient = new HttpClient { BaseAddress = new Uri("http://localhost:5000") };
            var response = await httpClient.GetAsync($"/api/devices/{deviceId}/config");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GetConfigResponse>();
                if (result != null && !string.IsNullOrEmpty(result.ConfigJson))
                {
                    var jsonDoc = System.Text.Json.JsonDocument.Parse(result.ConfigJson);
                    _editedConfig = System.Text.Json.JsonSerializer.Serialize(jsonDoc,
                        new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                }
                else
                {
                    _configError = "Empty configuration received";
                }
            }
            else
            {
                _configError = $"Failed to load config: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            _configError = $"Error: {ex.Message}";
        }
        finally
        {
            _configLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveConfig()
    {
        _saving = true;
        _saveError = string.Empty;
        _saveSuccess = string.Empty;
        StateHasChanged();

        try
        {
            try { System.Text.Json.JsonDocument.Parse(_editedConfig); }
            catch (System.Text.Json.JsonException ex)
            {
                _saveError = $"Invalid JSON: {ex.Message}";
                _saving = false;
                StateHasChanged();
                return;
            }

            var httpClient = new HttpClient { BaseAddress = new Uri("http://localhost:5000") };
            var payload = new SetConfigPayload { ConfigJson = _editedConfig };
            var response = await httpClient.PostAsJsonAsync($"/api/devices/{_editingDeviceId}/config", payload);

            if (response.IsSuccessStatusCode)
            {
                _saveSuccess = "Configuration saved. Device will use new config on next restart.";
                await Task.Delay(2000);
                CloseConfigEditor();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                _saveError = $"Failed to save: {errorText}";
            }
        }
        catch (Exception ex)
        {
            _saveError = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void CloseConfigEditor()
    {
        _showConfigEditor = false;
        _editingDeviceId = null;
        _editedConfig = string.Empty;
        _saveError = string.Empty;
        _saveSuccess = string.Empty;
        StateHasChanged();
    }

    private void OpenOtaModal(string deviceId)
    {
        _otaDeviceId = deviceId;
        _otaFileData = null;
        _otaFilename = string.Empty;
        _otaFileSize = 0;
        _otaError = string.Empty;
        _otaSuccess = string.Empty;
        _otaUploading = false;
        _showOtaModal = true;
        StateHasChanged();
    }

    private void CloseOtaModal()
    {
        _showOtaModal = false;
        _otaDeviceId = null;
        _otaFileData = null;
        StateHasChanged();
    }

    private async Task OtaFileSelected(InputFileChangeEventArgs e)
    {
        _otaError = string.Empty;
        _otaSuccess = string.Empty;
        var file = e.File;

        if (file.Size > 8 * 1024 * 1024)
        {
            _otaError = "File too large (max 8 MB)";
            _otaFileData = null;
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024).CopyToAsync(ms);
        _otaFileData = ms.ToArray();
        _otaFilename = file.Name;
        _otaFileSize = file.Size;
        StateHasChanged();
    }

    private async Task StartOtaFlash()
    {
        if (_otaFileData == null || string.IsNullOrEmpty(_otaDeviceId)) return;

        _otaUploading = true;
        _otaError = string.Empty;
        _otaSuccess = string.Empty;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_otaFileData), "firmware", _otaFilename);

            var response = await Http.PostAsync($"/api/ota/upload/{_otaDeviceId}", content);
            var body = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                _otaSuccess = $"OTA command sent. {_otaDeviceId} is flashing and will reboot shortly.";
                _otaFileData = null;
            }
            else
            {
                using var doc = System.Text.Json.JsonDocument.Parse(body);
                var msg = doc.RootElement.TryGetProperty("message", out var m) ? m.GetString() : body;
                _otaError = msg ?? "OTA failed";
            }
        }
        catch (Exception ex)
        {
            _otaError = $"Error: {ex.Message}";
        }
        finally
        {
            _otaUploading = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ClientRegistry.OnRelayStateChanged -= HandleRelayStateChanged;
        _timer?.Dispose();
    }

    private class DeviceInfo
    {
        public string ClientId { get; set; } = string.Empty;
        public string? DeviceType { get; set; }
        public string? FriendlyName { get; set; }
        public string? RemoteIp { get; set; }
        public DateTime FirstSeenUtc { get; set; }
        public DateTime LastHeartbeatUtc { get; set; }
        public int CommandPort { get; set; }
        public string[] Capabilities { get; set; } = Array.Empty<string>();
        public RelayInfo[]? Relays { get; set; }
        public Dictionary<string, string> RelayStates { get; set; } = new();

        public string DeviceId => ClientId;
        public string IpAddress => RemoteIp ?? "unknown";
        public DateTime LastSeen => LastHeartbeatUtc;
    }

    private class RelayInfo
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    private class GetConfigResponse
    {
        public string ConfigJson { get; set; } = string.Empty;
    }
}
