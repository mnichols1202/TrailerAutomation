@page "/sensors"
@rendermode InteractiveServer
@inject SensorReadingRegistry Registry
@inject SensorReadingRepository Repository
@inject ClientRegistry ClientRegistry
@implements IDisposable

<PageTitle>Sensors</PageTitle>

<div class="page-header">
    <h2 style="margin: 0; padding: 0;">Sensor Readings</h2>
    <div class="page-header-actions">
        <span class="toolbar-meta">
            <strong>@_totalCount</strong> readings in database
            &nbsp;·&nbsp;
            Updated <strong>@DateTime.Now.ToString("HH:mm:ss")</strong>
        </span>
        <button class="btn btn-secondary" @onclick="LoadData">↺ Refresh</button>
    </div>
</div>

@if (!_currentReadings.Any())
{
    <div class="empty-state">
        <span class="empty-state-icon" style="font-size:48px; opacity:0.3;">---</span>
        <p>No sensor readings yet. Waiting for devices to report…</p>
    </div>
}
else
{
    <div class="sensor-grid">
        @foreach (var reading in _currentReadings.OrderBy(r => r.ClientId))
        {
            var minutesAgo = (DateTime.UtcNow - reading.TimestampUtc).TotalMinutes;
            var isActive = minutesAgo < _staleThresholdMinutes;
            var tempF = reading.TemperatureC * 9.0 / 5.0 + 32;

            <div class="sensor-card @(isActive ? "active" : "stale")">
                <div class="sensor-card-header">
                    <span class="sensor-card-name">@reading.ClientId</span>
                    <span class="status @(isActive ? "status-active" : "status-inactive")">
                        @(isActive ? "Active" : "Stale")
                    </span>
                </div>
                <div class="sensor-card-body">
                    <div class="sensor-metric">
                        <span class="sensor-metric-label">Temperature</span>
                        <span class="sensor-metric-value temp">@reading.TemperatureC.ToString("F1")°C</span>
                        <span class="sensor-metric-sub">@tempF.ToString("F1")°F</span>
                    </div>
                    <div class="sensor-metric">
                        <span class="sensor-metric-label">Humidity</span>
                        <span class="sensor-metric-value humidity">@reading.HumidityPercent.ToString("F1")%</span>
                    </div>
                </div>
                <div class="sensor-card-footer">
                    <span>@reading.TimestampUtc.ToLocalTime().ToString("MMM dd HH:mm:ss")</span>
                    <span>@minutesAgo.ToString("F0")m ago</span>
                </div>
            </div>
        }
    </div>
}

<div class="info-card">
    <p>Auto-refreshes every 10 seconds. Readings older than @_staleThresholdMinutes minutes are marked <strong>Stale</strong>.</p>
    <ul>
        <li>Stale threshold = 3× the longest configured sensor interval</li>
        <li>IP: shown in device registry on the Devices page</li>
    </ul>
</div>

@code {
    private List<SensorReading> _currentReadings = new();
    private int _totalCount;
    private int _staleThresholdMinutes = 15;
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        LoadData();

        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                LoadData();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void LoadData()
    {
        _currentReadings = Registry.GetAllReadings().ToList();
        _totalCount = Repository.GetTotalCount();
        _staleThresholdMinutes = 15;
    }

    public void Dispose() => _timer?.Dispose();
}
