@page "/history"
@rendermode InteractiveServer
@inject SensorReadingRepository Repository
@inject IJSRuntime JS

<PageTitle>History</PageTitle>

<div class="page-header">
    <h2 style="margin: 0; padding: 0;">Sensor History — Last 24 Hours</h2>
    <div class="page-header-actions">
        <span class="toolbar-meta">
            <strong>@_readings.Count</strong> readings
        </span>
    </div>
</div>

<div class="card">
    <div style="padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
        <label class="form-label" for="clientSelect">Client</label>
        <select id="clientSelect" class="form-select" @onchange="OnClientChanged">
            @foreach (var client in _availableClients)
            {
                <option value="@client" selected="@(client == _selectedClient)">@client</option>
            }
        </select>

        <label class="form-label" for="unitSelect">Unit</label>
        <select id="unitSelect" class="form-select" @onchange="OnUnitChanged">
            <option value="C" selected="@(_useFahrenheit == false)">°C Celsius</option>
            <option value="F" selected="@(_useFahrenheit == true)">°F Fahrenheit</option>
        </select>

        <button class="btn btn-secondary" @onclick="LoadData">↺ Refresh</button>
        <button class="btn btn-danger" @onclick="ResetData">🗑 Reset All Data</button>

        @if (_isLoading)
        {
            <span class="toolbar-meta">Loading…</span>
        }
    </div>

    <div class="chart-container">
        <canvas id="sensorChart"></canvas>
    </div>
</div>

<div class="card">
    <h2>Statistics</h2>
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Avg Temperature</div>
            <div class="stat-value" style="color: var(--temp-color);">@FormatTemp(_avgTemp)</div>
            @if (!_useFahrenheit && _readings.Any())
            {
                <div class="stat-sub">@((_avgTemp * 9.0 / 5.0 + 32).ToString("F1"))°F</div>
            }
        </div>
        <div class="stat-card">
            <div class="stat-label">Min Temperature</div>
            <div class="stat-value" style="color: var(--humidity-color);">@FormatTemp(_minTemp)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Max Temperature</div>
            <div class="stat-value" style="color: var(--accent-red);">@FormatTemp(_maxTemp)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg Humidity</div>
            <div class="stat-value" style="color: var(--humidity-color);">@_avgHumidity.ToString("F1")%</div>
        </div>
    </div>
</div>

@code {
    private List<SensorReading> _readings = new();
    private List<string> _availableClients = new();
    private string _selectedClient = "";
    private bool _isLoading = false;
    private bool _useFahrenheit = false;

    private double _avgTemp;
    private double _minTemp;
    private double _maxTemp;
    private double _avgHumidity;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableClients();
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedUnit = await JS.InvokeAsync<string>("localStorage.getItem", "tempUnit");
            _useFahrenheit = savedUnit == "F";
            StateHasChanged();
        }

        if (_readings.Any())
        {
            await UpdateChart();
        }
    }

    private async Task LoadAvailableClients()
    {
        var from = DateTime.UtcNow.AddHours(-24);
        var allReadings = Repository.GetAllHistory(from, null, 10000).ToList();

        _availableClients = allReadings
            .Select(r => r.ClientId)
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        if (_availableClients.Any() && string.IsNullOrEmpty(_selectedClient))
            _selectedClient = _availableClients.First();
    }

    private async Task OnClientChanged(ChangeEventArgs e)
    {
        _selectedClient = e.Value?.ToString() ?? "";
        await LoadData();
    }

    private async Task OnUnitChanged(ChangeEventArgs e)
    {
        var unit = e.Value?.ToString() ?? "C";
        _useFahrenheit = unit == "F";
        await JS.InvokeVoidAsync("localStorage.setItem", "tempUnit", unit);
        StateHasChanged();
        await UpdateChart();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        var from = DateTime.UtcNow.AddHours(-24);

        _readings = string.IsNullOrEmpty(_selectedClient)
            ? new List<SensorReading>()
            : Repository.GetHistory(_selectedClient, from, null, 10000)
                .OrderBy(r => r.TimestampUtc)
                .ToList();

        CalculateStats();
        _isLoading = false;
    }

    private void CalculateStats()
    {
        if (_readings.Any())
        {
            _avgTemp     = _readings.Average(r => r.TemperatureC);
            _minTemp     = _readings.Min(r => r.TemperatureC);
            _maxTemp     = _readings.Max(r => r.TemperatureC);
            _avgHumidity = _readings.Average(r => r.HumidityPercent);
        }
        else
        {
            _avgTemp = _minTemp = _maxTemp = _avgHumidity = 0;
        }
    }

    private string FormatTemp(double tempC)
    {
        if (_useFahrenheit)
            return $"{tempC * 9.0 / 5.0 + 32:F1}°F";
        return $"{tempC:F1}°C";
    }

    private async Task UpdateChart()
    {
        if (!_readings.Any()) return;

        var labels      = _readings.Select(r => r.TimestampUtc.ToLocalTime().ToString("MM/dd HH:mm")).ToList();
        var tempData    = _readings.Select(r => _useFahrenheit ? r.TemperatureC * 9.0 / 5.0 + 32 : r.TemperatureC).ToList();
        var humidityData = _readings.Select(r => r.HumidityPercent).ToList();
        var tempUnit    = _useFahrenheit ? "°F" : "°C";

        await JS.InvokeVoidAsync("updateSensorChart", labels, tempData, humidityData, tempUnit);
    }

    private async Task ResetData()
    {
        var totalCount = Repository.GetTotalCount();
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete ALL {totalCount} sensor readings? This cannot be undone.");

        if (confirmed)
        {
            Repository.DeleteAll();
            await LoadAvailableClients();
            _readings = new List<SensorReading>();
            _selectedClient = _availableClients.FirstOrDefault() ?? "";
            CalculateStats();
            StateHasChanged();
            await UpdateChart();
        }
    }
}
