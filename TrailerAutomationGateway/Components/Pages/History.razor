@page "/history"
@rendermode InteractiveServer
@inject SensorReadingRepository Repository
@inject IJSRuntime JS

<PageTitle>Sensor History</PageTitle>

<div class="card">
    <h2>📈 Sensor History - Last 24 Hours</h2>
    
    <div style="margin-bottom: 20px;">
        <label for="clientSelect">Select Client: </label>
        <select id="clientSelect" @onchange="OnClientChanged" style="padding: 8px; border-radius: 4px; border: 1px solid #ddd;">
            @foreach (var client in _availableClients)
            {
                <option value="@client" selected="@(client == _selectedClient)">@client</option>
            }
        </select>
        
        <label for="unitSelect" style="margin-left: 20px;">Temperature Unit: </label>
        <select id="unitSelect" @onchange="OnUnitChanged" style="padding: 8px; border-radius: 4px; border: 1px solid #ddd;">
            <option value="C" selected="@(_useFahrenheit == false)">Celsius (°C)</option>
            <option value="F" selected="@(_useFahrenheit == true)">Fahrenheit (°F)</option>
        </select>
        
        <button class="refresh-btn" style="margin-left: 20px;" @onclick="LoadData">🔄 Refresh</button>
        
        <button class="refresh-btn btn-danger" style="margin-left: 20px;" @onclick="ResetData">🗑️ Reset All Data</button>
        
        @if (_isLoading)
        {
            <span style="margin-left: 20px; color: #7f8c8d;">Loading...</span>
        }
    </div>
    
    <div style="margin-bottom: 20px;">
        <p style="color: #7f8c8d;">
            Showing <strong>@_readings.Count</strong> readings from the last 24 hours
        </p>
    </div>
    
    <div style="position: relative; height: 400px;">
        <canvas id="sensorChart"></canvas>
    </div>
</div>

<div class="card">
    <h2>📊 Statistics</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
        <div>
            <div style="color: #7f8c8d; font-size: 14px;">Average Temperature</div>
            <div class="metric">@FormatTemp(_avgTemp)</div>
            @if (!_useFahrenheit)
            {
                <div style="color: #95a5a6; font-size: 14px;">@((_avgTemp * 9 / 5 + 32).ToString("F1"))°F</div>
            }
        </div>
        <div>
            <div style="color: #7f8c8d; font-size: 14px;">Min Temperature</div>
            <div class="metric" style="color: #3498db;">@FormatTemp(_minTemp)</div>
        </div>
        <div>
            <div style="color: #7f8c8d; font-size: 14px;">Max Temperature</div>
            <div class="metric" style="color: #e74c3c;">@FormatTemp(_maxTemp)</div>
        </div>
        <div>
            <div style="color: #7f8c8d; font-size: 14px;">Average Humidity</div>
            <div class="metric">@_avgHumidity.ToString("F1")%</div>
        </div>
    </div>
</div>

@code {
    private List<SensorReading> _readings = new();
    private List<string> _availableClients = new();
    private string _selectedClient = "";
    private bool _isLoading = false;
    private bool _useFahrenheit = false;
    
    private double _avgTemp;
    private double _minTemp;
    private double _maxTemp;
    private double _avgHumidity;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableClients();
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load temperature unit preference from localStorage
            var savedUnit = await JS.InvokeAsync<string>("localStorage.getItem", "tempUnit");
            _useFahrenheit = savedUnit == "F";
            StateHasChanged();
        }
        
        if (_readings.Any())
        {
            await UpdateChart();
        }
    }

    private async Task LoadAvailableClients()
    {
        var from = DateTime.UtcNow.AddHours(-24);
        var allReadings = Repository.GetAllHistory(from, null, 10000).ToList();
        
        _availableClients = allReadings
            .Select(r => r.ClientId)
            .Distinct()
            .OrderBy(c => c)
            .ToList();
        
        if (_availableClients.Any() && string.IsNullOrEmpty(_selectedClient))
        {
            _selectedClient = _availableClients.First();
        }
    }

    private async Task OnClientChanged(ChangeEventArgs e)
    {
        _selectedClient = e.Value?.ToString() ?? "";
        await LoadData();
    }

    private async Task OnUnitChanged(ChangeEventArgs e)
    {
        var unit = e.Value?.ToString() ?? "C";
        _useFahrenheit = unit == "F";
        
        // Save preference to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "tempUnit", unit);
        
        // Trigger chart update
        StateHasChanged();
        await UpdateChart();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        
        var from = DateTime.UtcNow.AddHours(-24);
        
        if (!string.IsNullOrEmpty(_selectedClient))
        {
            _readings = Repository.GetHistory(_selectedClient, from, null, 10000)
                .OrderBy(r => r.TimestampUtc)
                .ToList();
        }
        else
        {
            _readings = new List<SensorReading>();
        }
        
        CalculateStats();
        _isLoading = false;
    }

    private void CalculateStats()
    {
        if (_readings.Any())
        {
            _avgTemp = _readings.Average(r => r.TemperatureC);
            _minTemp = _readings.Min(r => r.TemperatureC);
            _maxTemp = _readings.Max(r => r.TemperatureC);
            _avgHumidity = _readings.Average(r => r.HumidityPercent);
        }
        else
        {
            _avgTemp = _minTemp = _maxTemp = _avgHumidity = 0;
        }
    }

    private string FormatTemp(double tempC)
    {
        if (_useFahrenheit)
        {
            var tempF = tempC * 9 / 5 + 32;
            return $"{tempF:F1}°F";
        }
        return $"{tempC:F1}°C";
    }

    private async Task UpdateChart()
    {
        if (!_readings.Any()) return;
        
        var labels = _readings.Select(r => r.TimestampUtc.ToLocalTime().ToString("MM/dd HH:mm")).ToList();
        var tempData = _readings.Select(r => _useFahrenheit ? r.TemperatureC * 9 / 5 + 32 : r.TemperatureC).ToList();
        var humidityData = _readings.Select(r => r.HumidityPercent).ToList();
        var tempUnit = _useFahrenheit ? "°F" : "°C";
        
        await JS.InvokeVoidAsync("updateSensorChart", labels, tempData, humidityData, tempUnit);
    }

    private async Task ResetData()
    {
        var totalCount = Repository.GetTotalCount();
        var confirmed = await JS.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to delete ALL {totalCount} sensor readings? This action cannot be undone!");
        
        if (confirmed)
        {
            var deletedCount = Repository.DeleteAll();
            Console.WriteLine($"[History] Deleted {deletedCount} sensor readings");
            
            await LoadAvailableClients();
            _readings = new List<SensorReading>();
            _selectedClient = _availableClients.FirstOrDefault() ?? "";
            CalculateStats();
            StateHasChanged();
        }
    }
}
