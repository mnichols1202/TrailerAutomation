{
    "version": "2.0.0",
    "tasks": [
        // ── .NET ──────────────────────────────────────────────────────────────
        {
            "label": "build-gateway",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/TrailerAutomationGateway/TrailerAutomationGateway.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-client",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/TrailerAutomationClientNet/TrailerAutomationClientNet.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-all",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/TrailerAutomation.sln"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "publish-gateway-pi",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/TrailerAutomationGateway/TrailerAutomationGateway.csproj",
                "-c", "Release",
                "-r", "linux-arm64",
                "--self-contained",
                "-p:PublishSingleFile=true",
                "-o", "${workspaceFolder}/TrailerAutomationGateway/bin/publish/linux-arm64"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-client-pi",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/TrailerAutomationClientNet/TrailerAutomationClientNet.csproj",
                "-c", "Release",
                "-r", "linux-arm64",
                "--no-self-contained",
                "-p:PublishSingleFile=true"
            ],
            "problemMatcher": "$msCompile"
        },

        // ── ESP32-S3 (two-pass: flash firmware first, then filesystem) ────────
        {
            "label": "S3: Build firmware",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e trailer_automation_client_s3",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientS3",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-esptoolpy;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"],
            "group": "build"
        },
        {
            "label": "S3: Flash firmware",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e trailer_automation_client_s3 --target upload",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientS3",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-esptoolpy;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "S3: Flash filesystem (uploadfs) — run AFTER firmware flash",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e trailer_automation_client_s3 --target uploadfs",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientS3",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-esptoolpy;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "S3: Monitor serial",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe device monitor -e trailer_automation_client_s3",
            "options": { "cwd": "${workspaceFolder}/TrailerAutomationClientS3" },
            "problemMatcher": []
        },

        // ── Pico W (ONE-PASS ONLY — unified image = firmware + LittleFS) ──────
        // WARNING: Never flash firmware-only to Pico — it will wipe config.json.
        // Always use the unified build target that combines both into one .uf2.
        {
            "label": "PicoW: Build unified image (firmware + LittleFS)",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e picow --target buildunified",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientPico",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-picotool-rp2040-earlephilhower;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"],
            "group": "build"
        },
        {
            "label": "PicoW: Flash unified image",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e picow --target upload",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientPico",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-picotool-rp2040-earlephilhower;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "PicoW: Monitor serial",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe device monitor -e picow",
            "options": { "cwd": "${workspaceFolder}/TrailerAutomationClientPico" },
            "problemMatcher": []
        },

        // ── Pico 2W (ONE-PASS ONLY — unified image = firmware + LittleFS) ─────
        // WARNING: Never flash firmware-only to Pico 2W — it will wipe config.json.
        // Always use the unified build target that combines both into one .uf2.
        {
            "label": "Pico2W: Build unified image (firmware + LittleFS)",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e pico2w --target buildunified",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientPico",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-picotool-rp2040-earlephilhower;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"],
            "group": "build"
        },
        {
            "label": "Pico2W: Flash unified image",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe run -e pico2w --target upload",
            "options": {
                "cwd": "${workspaceFolder}/TrailerAutomationClientPico",
                "env": { "PATH": "${env:USERPROFILE}\\.platformio\\packages\\tool-mklittlefs;${env:USERPROFILE}\\.platformio\\packages\\tool-picotool-rp2040-earlephilhower;${env:PATH}" }
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "Pico2W: Monitor serial",
            "type": "shell",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe device monitor -e pico2w",
            "options": { "cwd": "${workspaceFolder}/TrailerAutomationClientPico" },
            "problemMatcher": []
        }
    ]
}
